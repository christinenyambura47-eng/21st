{
  "buildCommand": "cd twentyfirst-connect && npm run build",
  "outputDirectory": "twentyfirst-connect/dist",
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": "https://two1st-electronics.onrender.com/api"
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/plans",
      "destination": "/index.html"
    },
    {
      "source": "/products",
      "destination": "/index.html"
    },
    {
      "source": "/coverage",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/faq",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    }
  ]
}
