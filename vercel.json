{
  "buildCommand": "cd twentyfirst-connect && npm run build",
  "outputDirectory": "twentyfirst-connect/dist",
  "framework": "vite",
  "regions": ["iad1"],
  "env": {
    "VITE_API_BASE_URL": {
      "description": "Backend API URL - e.g., https://api.example.com/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
